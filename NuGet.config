<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />

    <add
      key="nuget.org"
      value="https://api.nuget.org/v3/index.json"
      protocolVersion="3" />

    <add
      key="deltazulu-github"
      value="https://nuget.pkg.github.com/DeltaZulu-OU/index.json" />
  </packageSources>

  <packageSourceMapping>
    <packageSource key="deltazulu-github">
      <package pattern="DeltaZulu.*" />
    </packageSource>

    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>